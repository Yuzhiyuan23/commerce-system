# 后端 Dockerfile
FROM eclipse-temurin:21-jdk-alpine

WORKDIR /app

# 复制 Maven 构建好的 JAR 包
COPY target/commerce-system-backend-0.0.1-SNAPSHOT.jar app.jar

# 创建日志目录
RUN mkdir -p /var/log/commerce-system

# 暴露端口
EXPOSE 8080

# 启动命令
ENTRYPOINT ["java", "-Xms512m", "-Xmx1024m", "-jar", "app.jar", "--spring.profiles.active=prod"]
